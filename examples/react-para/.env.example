# Required Environment Variables

# SBC API Key - Get from https://app.stablecoin.xyz/
VITE_SBC_API_KEY=sbc-your-api-key-here

# Para API Key - Get from your Para dashboard
VITE_PARA_API_KEY=your-para-api-key

# Chain selection: 'baseSepolia' (default), 'base', 'radiusTestnet', or 'radius'
# VITE_CHAIN=baseSepolia

# Custom RPC URL (optional)
# VITE_RPC_URL=https://your-custom-rpc-url.com
